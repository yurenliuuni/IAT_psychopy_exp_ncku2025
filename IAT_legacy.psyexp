      </RoutineSettingsComponent>
      <CodeComponent name="code_8" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="total_rt = []&amp;#10;correct_responses = 0&amp;#10;total_trials = 0&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="total_rt = [];&amp;#10;correct_responses = 0;&amp;#10;total_trials = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((total_trials &gt; 0)) {&amp;#10;    mean_rt = util.round(((util.sum(total_rt) / total_rt.length) * 1000), 2);&amp;#10;    accuracy = util.round(((correct_responses / total_trials) * 100), 2);&amp;#10;    feedback_msg = `Mean RT: ${mean_rt} ms&amp;#10;Accuracy: ${accuracy}%`&amp;#10;;&amp;#10;} else {&amp;#10;    feedback_msg = &quot;No responses recorded.&quot;;&amp;#10;}&amp;#10;total_rt = [];&amp;#10;correct_responses = 0;&amp;#10;total_trials = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if total_trials &gt; 0:  # Avoid division by zero&amp;#10;    mean_rt = round(sum(total_rt) / len(total_rt) * 1000, 2)  # Convert to milliseconds&amp;#10;    accuracy = round((correct_responses / total_trials) * 100, 2)  # Percentage&amp;#10;    feedback_msg = f&quot;Mean RT: {mean_rt} ms\nAccuracy: {accuracy}%&quot;&amp;#10;else:&amp;#10;    feedback_msg = &quot;No responses recorded.&quot;&amp;#10;&amp;#10;total_rt = []  # Reset for next block&amp;#10;correct_responses = 0&amp;#10;total_trials = 0&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (key_resp.keys) {&amp;#10;    total_rt.push(key_resp.rt);&amp;#10;    total_trials += 1;&amp;#10;    if (key_resp.corr) {&amp;#10;        correct_responses += 1;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if key_resp.keys:  # If a key was pressed&amp;#10;    total_rt.append(key_resp.rt)  # Store reaction time&amp;#10;    total_trials += 1  # Count trials&amp;#10;    if key_resp.corr:  # Check if the response was correct&amp;#10;        correct_responses += 1&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="code_8" valType="code" updates="None" name="name"/>
      </CodeComponent>
